{
  "name": "dmarket-bot",
  "version": "0.7.1",
  "description": "DMarket Trading Bot Desktop Application",
  "main": "main/main.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "dev": "webpack serve --mode development --config renderer/webpack.config.js",
    "build": "cross-env NODE_ENV=production webpack --mode production --config renderer/webpack.config.js",
    "build:electron": "npm run build && cross-env NODE_ENV=production electron-builder --publish never",
    "build:win": "npm run build && cross-env NODE_ENV=production electron-builder --win --publish never",
    "build:mac": "npm run build && cross-env NODE_ENV=production electron-builder --mac --publish never",
    "dist": "npm run build && cross-env NODE_ENV=production electron-builder"
  },
  "keywords": [
    "dmarket",
    "trading",
    "bot",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@emotion/babel-plugin": "^11.13.5",
    "babel-loader": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "events": "^3.3.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.1.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mantine/core": "^8.3.13",
    "@mantine/dates": "^8.3.13",
    "@mantine/dropzone": "^8.3.13",
    "@mantine/form": "^8.3.13",
    "@mantine/hooks": "^8.3.13",
    "@mantine/notifications": "^8.3.13",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-table": "^8.21.3",
    "ag-grid-community": "^35.0.0",
    "ag-grid-react": "^35.0.0",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "electron-store": "^10.0.0",
    "mantine-datatable": "^8.3.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.1",
    "react-hook-form": "^7.69.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.3",
    "react-modal": "^3.16.3",
    "react-toastify": "^11.0.5",
    "recharts": "^3.6.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.2.1"
  }
}
